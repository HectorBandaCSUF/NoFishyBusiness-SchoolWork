[
  // This is a jsonc, not a json file. 
  // eval.py calls in: Line 68 TEST_CASES_PATH     = os.path.join(_EVAL_DIR, "test_cases.jsonc")

  // ═══════════════════════════════════════════════════════════════════════
  // FEATURE 1: HEALTH CHECK
  // ═══════════════════════════════════════════════════════════════════════
  {
    "test_name": "health_check",
    "feature_area": "Infrastructure",
    "difficulty": "Basic",
    "tags": ["connectivity"],
    "endpoint": "/health",
    "method": "GET",
    "input": null,
    "expected_label": "backend is reachable and returns ok",
    "assertions": [
      { "type": "required_all", "keywords": ["ok"] },
      { "type": "http_status",  "expected": 200 }
    ]
  },

  // ═══════════════════════════════════════════════════════════════════════
  // FEATURE 2: VOLUME CALCULATOR (The Mathematician)
  // ═══════════════════════════════════════════════════════════════════════

  {
    "test_name": "volume_precision_standard_tank",
    "feature_area": "Volume Calculator",
    "difficulty": "Basic",
    "tags": ["math"],
    "endpoint": "/volume",
    "method": "POST",
    "input": { "length": 24.0, "width": 12.0, "depth": 12.0 },
    "expected_label": "24x12x12 inches = 14.96 gallons, 124.77 lbs",
    "assertions": [
      { "type": "schema_keys",    "keys": ["volume_gallons", "weight_pounds"] },
      { "type": "numeric_range",  "field": "volume_gallons", "min": 14.9,  "max": 15.1  },
      { "type": "numeric_range",  "field": "weight_pounds",  "min": 124.0, "max": 125.5 },
      { "type": "http_status",    "expected": 200 }
    ]
  },
  {
    "test_name": "volume_large_tank",
    "feature_area": "Volume Calculator",
    "difficulty": "Basic",
    "tags": ["math"],
    "endpoint": "/volume",
    "method": "POST",
    "input": { "length": 72.0, "width": 18.0, "depth": 20.0 },
    "expected_label": "72x18x20 inches = ~112 gallons",
    "assertions": [
      { "type": "numeric_range", "field": "volume_gallons", "min": 110.0, "max": 115.0 },
      { "type": "http_status",   "expected": 200 }
    ]
  },
  {
    "test_name": "volume_zero_dimension_rejected",
    "feature_area": "Volume Calculator",
    "difficulty": "Basic",
    "tags": ["math", "validation"],
    "endpoint": "/volume",
    "method": "POST",
    "input": { "length": 0.0, "width": 12.0, "depth": 12.0 },
    "expected_label": "zero dimension must return validation error",
    "assertions": [
      { "type": "http_status", "expected": 422 }
    ]
  },
  {
    "test_name": "volume_negative_dimension_rejected",
    "feature_area": "Volume Calculator",
    "difficulty": "Basic",
    "tags": ["math", "validation"],
    "endpoint": "/volume",
    "method": "POST",
    "input": { "length": -10.0, "width": 12.0, "depth": 12.0 },
    "expected_label": "negative dimension must return validation error",
    "assertions": [
      { "type": "http_status", "expected": 422 }
    ]
  },
  {
    "test_name": "volume_non_numeric_rejected",
    "feature_area": "Volume Calculator",
    "difficulty": "Basic",
    "tags": ["math", "validation"],
    "endpoint": "/volume",
    "method": "POST",
    "input": { "length": "abc", "width": 12.0, "depth": 12.0 },
    "expected_label": "non-numeric input must return 422",
    "assertions": [
      { "type": "http_status", "expected": 422 }
    ]
  },
  {
    "test_name": "volume_tiny_nano_tank",
    "feature_area": "Volume Calculator",
    "difficulty": "Logic",
    "tags": ["math"],
    "endpoint": "/volume",
    "method": "POST",
    "input": { "length": 6.0, "width": 6.0, "depth": 6.0 },
    "expected_label": "6x6x6 nano tank = ~0.93 gallons",
    "assertions": [
      { "type": "numeric_range", "field": "volume_gallons", "min": 0.8, "max": 1.1 },
      { "type": "http_status",   "expected": 200 }
    ]
  },

  // ═══════════════════════════════════════════════════════════════════════
  // FEATURE 3: SPECIES TOOL (The Encyclopedia)
  // ═══════════════════════════════════════════════════════════════════════

  {
    "test_name": "species_guppy_schema",
    "feature_area": "Species Tool",
    "difficulty": "Basic",
    "tags": ["llm", "schema"],
    "endpoint": "/species",
    "method": "POST",
    "input": { "species_name": "Guppy" },
    "expected_label": "Guppy response has all required care sheet fields",
    "assertions": [
      {
        "type": "schema_keys",
        "keys": ["species_name","behavior","compatible_tank_mates",
                 "temperature_f","ph","hardness_dgh","min_tank_gallons",
                 "difficulty","maintenance_notes"]
      },
      { "type": "http_status", "expected": 200 }
    ]
  },
  {
    "test_name": "species_betta_schema",
    "feature_area": "Species Tool",
    "difficulty": "Basic",
    "tags": ["llm", "schema"],
    "endpoint": "/species",
    "method": "POST",
    "input": { "species_name": "Betta" },
    "expected_label": "Betta response has all required care sheet fields",
    "assertions": [
      {
        "type": "schema_keys",
        "keys": ["behavior","compatible_tank_mates","temperature_f","ph","min_tank_gallons"]
      }
    ]
  },
  {
    "test_name": "species_unknown_returns_404",
    "feature_area": "Species Tool",
    "difficulty": "Basic",
    "tags": ["validation"],
    "endpoint": "/species",
    "method": "POST",
    "input": { "species_name": "XyzUnknownFishSpecies999" },
    "expected_label": "unknown species returns not_found error",
    "assertions": [
      { "type": "required_all", "keywords": ["not_found"] },
      { "type": "http_status",  "expected": 404 }
    ]
  },
  {
    "test_name": "species_hallucination_fictional_fish",
    "feature_area": "Species Tool",
    "difficulty": "Logic",
    "tags": ["llm", "safety", "hallucination"],
    "endpoint": "/species",
    "method": "POST",
    "input": { "species_name": "Neon Fire Dragon Fish" },
    "expected_label": "fictional species must not be fabricated — should return not_found",
    "assertions": [
      { "type": "required_all",  "keywords": ["not_found"] },
      { "type": "forbidden_any", "keywords": ["behavior", "temperature_f"] },
      { "type": "http_status",   "expected": 404 }
    ]
  },
  {
    "test_name": "species_emoji_input_handled",
    "feature_area": "Species Tool",
    "difficulty": "Stress-Test",
    "tags": ["validation", "edge-case"],
    "endpoint": "/species",
    "method": "POST",
    "input": { "species_name": "🐠🐟🦈" },
    "expected_label": "emoji-only input should not crash — returns not_found or error",
    "assertions": [
      { "type": "forbidden_any", "keywords": ["500", "Internal Server Error"] }
    ]
  },
  {
    "test_name": "species_betta_guppy_compatibility_warning",
    "feature_area": "Species Tool",
    "difficulty": "Logic",
    "tags": ["llm", "compatibility"],
    "endpoint": "/assistant",
    "method": "POST",
    "input": {
      "message": "Can I keep a Betta with male Guppies in the same tank?",
      "history": []
    },
    "expected_label": "must warn about fin-nipping and aggression",
    "assertions": [
      { "type": "required_all",  "keywords": ["reply"] },
      { "type": "forbidden_any", "keywords": ["yes, they are compatible", "perfectly fine together"] }
    ]
  },
  {
    "test_name": "species_goldfish_shrimp_compatibility",
    "feature_area": "Species Tool",
    "difficulty": "Logic",
    "tags": ["llm", "compatibility"],
    "endpoint": "/assistant",
    "method": "POST",
    "input": {
      "message": "Can goldfish and shrimp live together?",
      "history": []
    },
    "expected_label": "must warn about goldfish eating shrimp and bio-load",
    "assertions": [
      { "type": "required_all",  "keywords": ["reply"] },
      { "type": "forbidden_any", "keywords": ["perfectly compatible", "great tank mates"] }
    ]
  },

  // ═══════════════════════════════════════════════════════════════════════
  // FEATURE 4: MAINTENANCE GUIDE (The Scheduler)
  // ═══════════════════════════════════════════════════════════════════════

  {
    "test_name": "maintenance_basic_schema",
    "feature_area": "Maintenance Guide",
    "difficulty": "Basic",
    "tags": ["llm", "schema"],
    "endpoint": "/maintenance",
    "method": "POST",
    "input": { "tank_gallons": 20.0, "fish_count": 5, "fish_species": ["Guppy"] },
    "expected_label": "maintenance response has all required fields",
    "assertions": [
      {
        "type": "schema_keys",
        "keys": ["nitrogen_cycle", "feeding", "weekly_tasks", "monthly_tasks"]
      }
    ]
  },
  {
    "test_name": "maintenance_nitrogen_cycle_stages",
    "feature_area": "Maintenance Guide",
    "difficulty": "Logic",
    "tags": ["llm", "biology"],
    "endpoint": "/maintenance",
    "method": "POST",
    "input": { "tank_gallons": 20.0, "fish_count": 5, "fish_species": ["Neon Tetra"] },
    "expected_label": "nitrogen cycle explanation must cover all 3 stages",
    "assertions": [
      { "type": "required_all", "keywords": ["ammonia", "nitrite", "nitrate"] }
    ]
  },
  {
    "test_name": "maintenance_bioload_low",
    "feature_area": "Maintenance Guide",
    "difficulty": "Logic",
    "tags": ["llm", "bioload"],
    "endpoint": "/maintenance",
    "method": "POST",
    "input": { "tank_gallons": 20.0, "fish_count": 2, "fish_species": ["Guppy"] },
    "expected_label": "low bioload — lighter maintenance schedule expected",
    "assertions": [
      { "type": "schema_keys", "keys": ["weekly_tasks", "monthly_tasks"] }
    ]
  },
  {
    "test_name": "maintenance_bioload_high",
    "feature_area": "Maintenance Guide",
    "difficulty": "Logic",
    "tags": ["llm", "bioload"],
    "endpoint": "/maintenance",
    "method": "POST",
    "input": { "tank_gallons": 20.0, "fish_count": 15, "fish_species": ["Goldfish"] },
    "expected_label": "high bioload — must recommend more frequent maintenance",
    "assertions": [
      { "type": "required_all",  "keywords": ["water change"] },
      { "type": "schema_keys",   "keys": ["weekly_tasks"] }
    ]
  },
  {
    "test_name": "maintenance_pleco_specific_tasks",
    "feature_area": "Maintenance Guide",
    "difficulty": "Logic",
    "tags": ["llm", "species-specific"],
    "endpoint": "/maintenance",
    "method": "POST",
    "input": { "tank_gallons": 55.0, "fish_count": 3, "fish_species": ["Pleco", "Guppy"] },
    "expected_label": "Pleco in tank — schedule should mention algae and gravel vacuuming",
    "assertions": [
      { "type": "required_all", "keywords": ["algae", "gravel"] }
    ]
  },
  {
    "test_name": "maintenance_free_form_input",
    "feature_area": "Maintenance Guide",
    "difficulty": "Stress-Test",
    "tags": ["llm", "free-form"],
    "endpoint": "/maintenance",
    "method": "POST",
    "input": {
      "tank_gallons": 30.0,
      "fish_count": 8,
      "fish_species": ["Some tetras", "a couple of corys", "one pleco"]
    },
    "expected_label": "free-form species names should not crash the backend",
    "assertions": [
      { "type": "forbidden_any", "keywords": ["500", "Internal Server Error", "rag_error"] }
    ]
  },

