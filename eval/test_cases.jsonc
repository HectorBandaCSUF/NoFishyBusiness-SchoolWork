  // ═══════════════════════════════════════════════════════════════════════
  // FEATURE 6: CHEMISTRY ANALYZER (The Interpreter)
  // ═══════════════════════════════════════════════════════════════════════

  {
    "test_name": "chemistry_basic_schema",
    "feature_area": "Chemistry Analyzer",
    "difficulty": "Basic",
    "tags": ["llm", "schema"],
    "endpoint": "/chemistry",
    "method": "POST",
    "input": { "description": "ammonia is 0.5 ppm, pH 7.2", "image_base64": null },
    "expected_label": "chemistry response has parameters and summary",
    "assertions": [
      { "type": "schema_keys", "keys": ["parameters", "summary"] }
    ]
  },
  {
    "test_name": "chemistry_toxicity_high_ammonia_high_ph",
    "feature_area": "Chemistry Analyzer",
    "difficulty": "Logic",
    "tags": ["llm", "biology", "safety"],
    "endpoint": "/chemistry",
    "method": "POST",
    "input": {
      "description": "ammonia is 2.0 ppm, nitrite is 1.0 ppm, pH is 8.5",
      "image_base64": null
    },
    "expected_label": "high ammonia at high pH is extremely toxic — must demand immediate water change",
    "assertions": [
      { "type": "required_all",  "keywords": ["danger", "water change"] },
      { "type": "forbidden_any", "keywords": ["safe", "no action needed"] }
    ]
  },
  {
    "test_name": "chemistry_zero_nitrate_plant_deficiency",
    "feature_area": "Chemistry Analyzer",
    "difficulty": "Logic",
    "tags": ["llm", "biology"],
    "endpoint": "/chemistry",
    "method": "POST",
    "input": {
      "description": "nitrate is 0 ppm, ammonia 0 ppm, nitrite 0 ppm, pH 7.0",
      "image_base64": null
    },
    "expected_label": "zero nitrate is safe for fish but suggests nitrogen deficiency for plants",
    "assertions": [
      { "type": "required_all",  "keywords": ["safe"] },
      { "type": "forbidden_any", "keywords": ["danger"] }
    ]
  },
  {
    "test_name": "chemistry_off_topic_refused",
    "feature_area": "Chemistry Analyzer",
    "difficulty": "Basic",
    "tags": ["safety", "topic-guard"],
    "endpoint": "/chemistry",
    "method": "POST",
    "input": { "description": "What is the stock price of Apple today?", "image_base64": null },
    "expected_label": "off-topic chemistry query must be refused or return no_parameters",
    "assertions": [
      { "type": "forbidden_any", "keywords": ["Apple", "stock", "AAPL"] }
    ]
  },
  {
    "test_name": "chemistry_free_form_sentence",
    "feature_area": "Chemistry Analyzer",
    "difficulty": "Logic",
    "tags": ["llm", "free-form"],
    "endpoint": "/chemistry",
    "method": "POST",
    "input": {
      "description": "My shrimp are dying and the water smells bad. I tested and ammonia seems really high.",
      "image_base64": null
    },
    "expected_label": "free-form description mentioning ammonia should trigger analysis",
    "assertions": [
      { "type": "forbidden_any", "keywords": ["500", "Internal Server Error"] }
    ]
  },

  // ═══════════════════════════════════════════════════════════════════════
  // FEATURE 7: IMAGE SCANNER (The Specialist)
  // ═══════════════════════════════════════════════════════════════════════

  {
    "test_name": "image_scan_valid_jpeg_schema",
    "feature_area": "Image Scanner",
    "difficulty": "Basic",
    "tags": ["llm", "multimodal", "schema"],
    "endpoint": "/image-scan",
    "method": "POST",
    "content_type": "multipart",
    "input": { "file_path": "test_images/test_fish.jpg" },
    "expected_label": "valid image returns species_name, confidence, care_summary, health_assessment",
    "assertions": [
      {
        "type": "schema_keys",
        "keys": ["species_name", "confidence", "care_summary", "health_assessment"]
      },
      { "type": "http_status", "expected": 200 }
    ]
  },
  {
    "test_name": "image_scan_wrong_format_rejected",
    "feature_area": "Image Scanner",
    "difficulty": "Basic",
    "tags": ["validation", "multimodal"],
    "endpoint": "/image-scan",
    "method": "POST",
    "content_type": "multipart",
    "input": { "file_path": "test_images/test_document.pdf" },
    "expected_label": "non-JPEG/PNG file must return 400 validation_error",
    "assertions": [
      { "type": "required_all", "keywords": ["validation_error"] },
      { "type": "http_status",  "expected": 400 }
    ]
  },
  {
    "test_name": "image_scan_inconclusive_confidence_invariant",
    "feature_area": "Image Scanner",
    "difficulty": "Logic",
    "tags": ["llm", "multimodal", "schema"],
    "endpoint": "/image-scan",
    "method": "POST",
    "content_type": "multipart",
    "input": { "file_path": "test_images/test_fish.jpg" },
    "expected_label": "if species_name is null, confidence must be inconclusive",
    "assertions": [
      { "type": "schema_keys", "keys": ["confidence", "health_assessment"] }
    ]
  },

